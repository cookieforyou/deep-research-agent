# 后端 Spring Boot 服务地址（服务端代理用）
BACKEND_URL=http://localhost:8080
# 后端地址（客户端直连用，SSE 需要绕过 Next.js 代理）
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# 应用名称
NEXT_PUBLIC_APP_NAME=DeepResearch

# 默认租户
NEXT_PUBLIC_DEFAULT_TENANT=default

# Casdoor 认证配置
NEXT_PUBLIC_AUTH_URL=your-casdoor-service-url
NEXT_PUBLIC_AUTH_CLIENT_ID=your-casdoor-application-client-id

# SSE 配置
NEXT_PUBLIC_SSE_RECONNECT_MAX=5
NEXT_PUBLIC_SSE_HEARTBEAT_TIMEOUT=30000

# 最大查询长度
NEXT_PUBLIC_MAX_QUERY_LENGTH=5000
