# 后端 Spring Boot 服务地址
BACKEND_URL=http://localhost:8080

# 应用名称
NEXT_PUBLIC_APP_NAME=DeepResearch

# 默认租户
NEXT_PUBLIC_DEFAULT_TENANT=default

# Casdoor 认证配置
NEXT_PUBLIC_AUTH_URL=https://auth.hyperinfer.top
NEXT_PUBLIC_AUTH_CLIENT_ID=9172d870f69845e615f5

# SSE 配置
NEXT_PUBLIC_SSE_RECONNECT_MAX=5
NEXT_PUBLIC_SSE_HEARTBEAT_TIMEOUT=30000

# 最大查询长度
NEXT_PUBLIC_MAX_QUERY_LENGTH=5000
