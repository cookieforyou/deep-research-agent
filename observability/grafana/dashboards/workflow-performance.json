{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus 数据源",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.6.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "heatmap", "name": "Heatmap", "version": "" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "工作流节点性能、搜索性能、缓存命中率",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "工作流节点耗时 P95 (5m)",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 10 }, { "color": "red", "value": 30 }] }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le, node) (rate(deepresearch_workflow_node_duration_seconds_bucket[5m])))",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "节点耗时趋势 (P50/P95)",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le, node) (rate(deepresearch_workflow_node_duration_seconds_bucket[5m])))",
          "legendFormat": "P50 — {{node}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le, node) (rate(deepresearch_workflow_node_duration_seconds_bucket[5m])))",
          "legendFormat": "P95 — {{node}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "工作流完成数 (5m rate)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        {
          "expr": "sum by(intent, status) (rate(deepresearch_workflow_completed_total_total[5m]))",
          "legendFormat": "{{intent}} — {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "工作流成功率 (1h)",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "#EAB308", "value": 0.9 }, { "color": "green", "value": 0.99 }] }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(deepresearch_workflow_completed_total_total{status=\"success\"}[1h])) / (sum(rate(deepresearch_workflow_completed_total_total[1h])) > 0)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "搜索延迟 P95 (按引擎)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le, engine) (rate(deepresearch_search_latency_seconds_bucket[5m])))",
          "legendFormat": "{{engine}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "搜索结果数 (5m rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 70 }
        }
      },
      "targets": [
        {
          "expr": "sum by(engine) (rate(deepresearch_search_results_total_total[5m]))",
          "legendFormat": "{{engine}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "缓存命中率 (10m avg)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "#EAB308", "value": 10 }, { "color": "green", "value": 50 }] }
        }
      },
      "targets": [
        {
          "expr": "(sum(rate(deepresearch_cache_access_total_total{result=\"hit\"}[10m])) / (sum(rate(deepresearch_cache_access_total_total[10m])) > 0)) * 100",
          "legendFormat": "命中率",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "搜索降级率 (10m)",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 25 }, { "color": "red", "value": 50 }] }
        }
      },
      "targets": [
        {
          "expr": "(sum(rate(deepresearch_search_fallback_total_total[10m])) / (sum(rate(deepresearch_search_calls_total_total[10m])) > 0)) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "缓存访问趋势 (hit vs miss)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        {
          "expr": "sum by(result) (rate(deepresearch_cache_access_total_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["deepresearch", "workflow", "performance", "search", "cache"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "数据源",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"] },
  "timezone": "browser",
  "title": "工作流性能",
  "uid": "deepresearch-workflow-performance",
  "version": 1
}
