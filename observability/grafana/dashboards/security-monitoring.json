{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus 数据源",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.6.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "PII 脱敏、Prompt 注入检测、CircuitBreaker 状态、Eval 评分",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "PII 脱敏速率 (5m rate, 按类型)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "mode": "normal" }, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum by(type) (rate(deepresearch_security_pii_masked_total_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "PII 脱敏总数 (24h)",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "sum(increase(deepresearch_security_pii_masked_total_total[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "PII 脱敏分布 (24h, 按类型)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 80 }
        }
      },
      "targets": [
        {
          "expr": "sum by(type) (increase(deepresearch_security_pii_masked_total_total[24h]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Prompt 注入检测速率 (5m, 按模式)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "mode": "normal" }, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum by(pattern) (rate(deepresearch_security_injection_detected_total_total[5m]))",
          "legendFormat": "{{pattern}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "注入检测总数 (24h)",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 1 }, { "color": "red", "value": 10 }] }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(deepresearch_security_injection_detected_total_total[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "注入检测类型分布 (24h)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 80 }
        }
      },
      "targets": [
        {
          "expr": "sum by(pattern) (increase(deepresearch_security_injection_detected_total_total[24h]))",
          "legendFormat": "{{pattern}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CircuitBreaker 状态",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 2,
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{name=~\"llm-circuit-breaker|search-circuit-breaker\"}",
          "legendFormat": "{{name}} — {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "CB 失败率 (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 25 }, { "color": "red", "value": 50 }] }
        }
      },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_failure_rate_percent{name=~\"llm-circuit-breaker|search-circuit-breaker\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Eval 评分趋势",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 5,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "#EAB308", "value": 3.0 }, { "color": "green", "value": 4.0 }] }
        }
      },
      "targets": [
        {
          "expr": "deepresearch_eval_score",
          "legendFormat": "整体评分",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "当前 Eval 评分",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 5,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "#EAB308", "value": 3.0 }, { "color": "green", "value": 4.0 }] }
        }
      },
      "targets": [
        {
          "expr": "deepresearch_eval_score",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "搜索降级趋势 (按 from→to)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      },
      "targets": [
        {
          "expr": "sum by(from, to) (rate(deepresearch_search_fallback_total_total[5m]))",
          "legendFormat": "{{from}} → {{to}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["deepresearch", "security", "pii", "injection", "eval"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "数据源",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"] },
  "timezone": "browser",
  "title": "安全监控",
  "uid": "deepresearch-security-monitoring",
  "version": 1
}
