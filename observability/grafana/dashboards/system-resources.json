{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus 数据源",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.6.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "JVM 内存/GC、HTTP 请求/延迟、CPU、线程数",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "JVM 堆内存使用",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "mode": "normal" }, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", id=~\"G1 Eden Space|G1 Survivor Space|G1 Old Gen\"}",
          "legendFormat": "{{id}} — used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "Heap Max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "堆内存使用率",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 70 }, { "color": "red", "value": 90 }] }
        }
      },
      "targets": [
        {
          "expr": "(sum(jvm_memory_used_bytes{area=\"heap\"}) / sum(jvm_memory_max_bytes{area=\"heap\"})) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "非堆内存 (Metaspace + CodeCache + 其他)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "mode": "normal" }, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"nonheap\"}",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GC 暂停时间 (1m rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum[1m])",
          "legendFormat": "{{action}} — {{cause}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "GC 总暂停时间 (1h)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "sum(increase(jvm_gc_pause_seconds_sum[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "GC 次数 (1h)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "sum(increase(jvm_gc_pause_seconds_count[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "应用运行时间",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "process_uptime_seconds",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP 请求速率 (5m, 按状态码)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "mode": "normal" }, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum by(status) (rate(http_server_requests_seconds_count[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "HTTP 5xx 错误率 (5m)",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "targets": [
        {
          "expr": "(sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / (sum(rate(http_server_requests_seconds_count[5m])) > 0)) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP 请求延迟 P50/P95/P99",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU 使用率",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      },
      "targets": [
        {
          "expr": "system_cpu_usage",
          "legendFormat": "系统 CPU",
          "refId": "A"
        },
        {
          "expr": "process_cpu_usage",
          "legendFormat": "进程 CPU",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "活跃线程数",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "活跃线程",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads",
          "legendFormat": "守护线程",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "JVM 线程总数 (瞬时)",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "内存使用 (总堆, 瞬时)",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["deepresearch", "system", "jvm", "http", "resources"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "数据源",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"] },
  "timezone": "browser",
  "title": "系统资源",
  "uid": "deepresearch-system-resources",
  "version": 1
}
