{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus 数据源",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.6.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "heatmap", "name": "Heatmap", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "LLM Token 消耗、成本、延迟和调用分布概览",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Token 消耗趋势 (5m rate)",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        {
          "expr": "sum by(agent) (rate(deepresearch_llm_tokens_input_total[5m]))",
          "legendFormat": "{{agent}} — input",
          "refId": "A"
        },
        {
          "expr": "sum by(agent) (rate(deepresearch_llm_tokens_output_total[5m]))",
          "legendFormat": "{{agent}} — output",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "成本趋势 (USD, 5m rate)",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "USD",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        {
          "expr": "sum by(agent, tier) (rate(deepresearch_llm_cost_estimated_total[5m]) / 1000000)",
          "legendFormat": "{{agent}} ({{tier}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "LLM 调用延迟 — P50 / P95 / P99",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le, agent, tier) (rate(deepresearch_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "P50 — {{agent}} ({{tier}})",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le, agent, tier) (rate(deepresearch_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "P95 — {{agent}} ({{tier}})",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le, agent, tier) (rate(deepresearch_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "P99 — {{agent}} ({{tier}})",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "type": "heatmap",
      "title": "延迟热力图 (按 Agent+Tier)",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "sum by(le, agent, tier) (rate(deepresearch_llm_latency_seconds_bucket[5m]))",
          "legendFormat": "{{agent}} ({{tier}})",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Agent 调用次数占比 (1h)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "sum by(agent) (increase(deepresearch_llm_calls_total_total[1h]))",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "模型降级次数 (1h)",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 1 }, { "color": "red", "value": 5 }] } }
      },
      "targets": [
        {
          "expr": "sum(increase(deepresearch_llm_fallback_total_total[1h]))",
          "legendFormat": "降级次数",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "累计 Token 消耗 (24h)",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "sum(increase(deepresearch_llm_tokens_input_total[24h])) + sum(increase(deepresearch_llm_tokens_output_total[24h]))",
          "legendFormat": "Tokens",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "累计成本 (24h, USD)",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "USD" }
      },
      "targets": [
        {
          "expr": "sum(increase(deepresearch_llm_cost_estimated_total[24h])) / 1000000",
          "legendFormat": "Cost",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Token 使用分布 — P50/P95 (24h, 按 Agent)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 80 }
        }
      },
      "targets": [
        {
          "expr": "sum by(agent) (increase(deepresearch_llm_tokens_input_total[24h])) + sum by(agent) (increase(deepresearch_llm_tokens_output_total[24h]))",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "每次调用平均 Token 数 (5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      },
      "targets": [
        {
          "expr": "sum by(agent) (rate(deepresearch_llm_tokens_input_total[5m]) + rate(deepresearch_llm_tokens_output_total[5m])) / sum by(agent) (rate(deepresearch_llm_calls_total_total[5m]))",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Spring AI 内置 — ChatClient 调用速率 (5m, 按状态)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "mode": "normal" }, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum by(status) (rate(spring_ai_chat_client_requests_seconds_count[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Spring AI 内置 — Token 消耗速率 (5m, 按类型)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "mode": "normal" }, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum by(token_type) (rate(spring_ai_chat_model_token_usage_total[5m]))",
          "legendFormat": "{{token_type}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["deepresearch", "llm", "token", "cost"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "数据源",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"] },
  "timezone": "browser",
  "title": "LLM 概览",
  "uid": "deepresearch-llm-overview",
  "version": 1
}
